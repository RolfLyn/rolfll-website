---
import Layout from '../layouts/Layout.astro';
import Eyebrow from '../components/Eyebrow.astro';
import { LINKEDIN_URL, GITHUB_URL, AAU_PROFILE_URL } from '../data/social';
---
<Layout
  title="Home"
  description="Rolf Lyneborg Lund: Lead People Analytics Specialist at Grundfos and Associate Professor in Social Data Science at AAU."
>
  <section class="reveal">
    <Eyebrow index="01" label="about" />
    <h1>I build machine learning systems on human data, and study what they actually do.</h1>
    <p>
      Lead People Analytics Specialist at Grundfos, where I put applied AI into production on
      real HR problems. Associate Professor in Social Data Science at Aalborg University, where I
      research the same systems from the outside. The practice keeps the research honest. The
      research keeps the practice from believing its own hype.
    </p>
    <p class="hero__focus">focus: applied-ml, sociology, behavioral-data</p>
  </section>
  <section class="hero-links reveal">
    <a href={LINKEDIN_URL} target="_blank" rel="noopener noreferrer">LinkedIn</a>
    <a href={GITHUB_URL} target="_blank" rel="noopener noreferrer">GitHub</a>
    <a href={AAU_PROFILE_URL} target="_blank" rel="noopener noreferrer">Academic profile</a>
  </section>
</Layout>
