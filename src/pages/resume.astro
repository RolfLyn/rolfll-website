---
import Layout from '../layouts/Layout.astro';
import ResumeEntry from '../components/ResumeEntry.astro';
import { getCollection } from 'astro:content';

const entries = await getCollection('resume');
const byType = (type: string) =>
  entries.filter((entry) => entry.data.type === type).sort((a, b) => a.data.order - b.data.order);

const sections = [
  { type: 'experience', heading: 'Experience' },
  { type: 'education', heading: 'Education' },
  { type: 'competency', heading: 'Competencies' },
  { type: 'interest', heading: 'Personal interests' },
];
---
<Layout title="Resume" description="Professional experience, education, and competencies.">
  <section class="page-head">
    <div class="page-head__rail">
      <div class="page-head__rail-cmd">$ cat cv<span class="cur" aria-hidden="true">▊</span></div>
      <div class="page-head__rail-label">index</div>
      <div>03 / resume</div>
    </div>
    <div class="page-head__body">
      <h1>Resume</h1>
      <p>
        Fifteen years turning human behavior into computational questions, across industry
        and academia.
      </p>
    </div>
  </section>

  <section class="resume-list">
    {sections.map(({ type, heading }) => (
      <div class="resume-section reveal">
        <div class="resume-section__head">{heading}</div>
        <div class="resume-section__body">
          {byType(type).map((entry) => (
            <ResumeEntry
              title={entry.data.title}
              org={entry.data.org}
              dateRange={entry.data.dateRange}
              description={entry.data.description}
            />
          ))}
        </div>
      </div>
    ))}
  </section>
</Layout>
