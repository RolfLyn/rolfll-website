---
import type { ProjectData } from '../content/schemas';

type Props = Pick<ProjectData, 'title' | 'subtitle' | 'dateRange' | 'tags' | 'description' | 'list'> & {
  num: string;
};
const { num, title, subtitle, dateRange, tags, description, list } = Astro.props;
---
<article class="project reveal">
  <div class="project__num">{num}</div>
  <div class="project__body">
    <h2>{title}</h2>
    {subtitle && <div class="project__subtitle">{subtitle}</div>}
    {dateRange && <div class="project__subtitle">{dateRange}</div>}
    {description && <p class="project__desc">{description}</p>}
    {list && (
      <ul class="project__list">
        {list.map((item) => <li>{item}</li>)}
      </ul>
    )}
    <div class="project__tags">
      {tags.map((tag) => <span class="tag">{tag}</span>)}
    </div>
  </div>
</article>
